{
  "name": "@istracked/datagrid-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite playground",
    "sync:tokens": "node scripts/sync-tokens.mjs",
    "tokens:check": "node scripts/sync-tokens.mjs --check",
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "vitest run packages/",
    "test:scripts": "node --test scripts/__tests__/*.test.mjs",
    "test:watch": "vitest packages/",
    "test:coverage": "vitest run packages/ --coverage",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b packages/*/tsconfig.build.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "validate": "tsc --noEmit && pnpm run build && vitest run packages/",
    "docs": "typedoc",
    "docs:open": "typedoc && open docs/index.html"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^9.0.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/jest-dom": "~6.6.3",
    "@testing-library/react": "~16.2.0",
    "@testing-library/user-event": "~14.5.2",
    "@types/react": "~19.0.8",
    "@types/react-dom": "~19.0.3",
    "@vitest/browser": "3.0.9",
    "@vitest/coverage-v8": "3.0.9",
    "eslint": "~9.19.0",
    "eslint-plugin-storybook": "^10.3.5",
    "fake-indexeddb": "^6.0.1",
    "fast-check": "^3.22.0",
    "jsdom": "~25.0.1",
    "playwright": "^1.59.1",
    "prettier": "~3.4.2",
    "react": "~19.0.0",
    "react-dom": "~19.0.0",
    "storybook": "^10.3.5",
    "tsup": "~8.4.0",
    "typedoc": "^0.28.19",
    "typescript": "~5.7.3",
    "vite": "~6.1.0",
    "vitest": "~3.0.5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
