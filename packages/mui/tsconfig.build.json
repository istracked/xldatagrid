{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "paths": {
      "@istracked/datagrid-core": ["../core/src/index.ts"],
      "@istracked/datagrid-react": ["../react/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "src/**/__tests__"],
  "references": [
    { "path": "../core/tsconfig.build.json" },
    { "path": "../react/tsconfig.build.json" }
  ]
}
